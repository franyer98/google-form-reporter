# ID de la hoja de cálculo vinculada al Google Form
# (lo encontrás en la URL: https://docs.google.com/spreadsheets/d/EL_ID/edit)
SHEET_ID=

# Nombre de la pestaña de respuestas del formulario
WORKSHEET_NAME=Respuestas de formulario 1

# Ruta al archivo de credenciales de la cuenta de servicio
GOOGLE_CREDENTIALS_PATH=credentials.json

# Carpeta donde se guardan los reportes generados
OUTPUT_DIR=reportes
